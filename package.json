{
  "name": "bake-app",
  "version": "1.0.0",
  "main": "dist/apps/api/main.js",
  "description": "Unified Café-Bakery Automation Platform",
  "license": "MIT",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch --exec \"node --loader ts-node/esm\" --ext ts",
    "build": "nest build apps/api",
    "build:prod": "nest build apps/api -- --webpack",
    "test": "jest",
    "lint": "eslint",
    "serve:api": "nest start --watch",
    "serve:pos": "npx vite --config apps/pos-app/vite.config.ts",
    "serve:admin": "npx vite --config apps/admin-dashboard/vite.config.ts",
    "serve:kitchen": "npx vite --config apps/kitchen-screen/vite.config.ts",
    "serve:hub": "npx vite --config apps/hub-app/vite.config.ts",
    "serve:mobile": "cd apps/mobile-app && expo start",
    "serve:ordering": "nx serve ordering-app",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.0.0",
