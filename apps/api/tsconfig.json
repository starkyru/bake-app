{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    // paths are relative to this config's directory (apps/api)
    "rootDir": "src",
    // compile output will land in workspace-level dist/apps/api
    "outDir": "../../dist/apps/api",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2020"
  },
  "files": ["src/main.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "src/**/__tests__/**"
  ]
}
