{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/npm.json",
  "plugins": [
    {
      "plugin": "@nrwl/nest/plugin",
      "options": {
        "projectType": "application"
      }
    }
  ],
  "nxCloudId": "bake-app",
  "defaultProject": "api",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "targetDefaults": {
    "build": {
      "cache": true
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  }
}
