{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2020",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@bake-app/api/*": ["apps/api/src/*"],
      "@bake-app/pos-app/*": ["apps/pos-app/src/*"],
      "@bake-app/admin-dashboard/*": ["apps/admin-dashboard/src/*"],
      "@bake-app/kitchen-screen/*": ["apps/kitchen-screen/src/*"],
      "@bake-app/hub-app/*": ["apps/hub-app/src/*"],
      "@bake-app/shared-types": ["libs/shared-types/src/index.ts"],
      "@bake-app/react/auth": ["libs/react/auth/src/index.ts"],
      "@bake-app/react/api-client": ["libs/react/api-client/src/index.ts"],
      "@bake-app/react/store": ["libs/react/store/src/index.ts"],
      "@bake-app/react/ui": ["libs/react/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
